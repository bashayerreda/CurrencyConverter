<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/converterFragment">

    <fragment
        android:id="@+id/converterFragment"
        android:name="com.example.paymobtask.presentation.currencyconverter.CurrencyConverterFragment"
        android:label="@string/app_name" >
        <action
            android:id="@+id/action_converterFragment_to_historyFragment"
            app:destination="@id/historyFragment" />
    </fragment>

    <fragment
        android:id="@+id/historyFragment"
        android:name="com.example.paymobtask.presentation.history.CurrencyConversionHistoryFragment"
        android:label="History">

        <argument
            android:name="from"
            app:argType="string" />

        <argument
            android:name="to"
            app:argType="string" />
    </fragment>



</navigation>